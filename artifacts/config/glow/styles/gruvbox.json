{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#ebdbb2",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n"
  },
  "h1": {
    "prefix": "# ",
    "suffix": " #",
    "color": "#fbf1c7",
    "background_color": "#3c3836",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "suffix": " ##",
    "color": "#fbf1c7",
    "bold": true,
    "italic": true
  },
  "h3": {
    "prefix": "### ",
    "suffix": " ###",
    "color": "#fbf1c7",
    "bold": true,
    "italic": false
  },
  "h4": {
    "prefix": "#### ",
    "suffix": " ####",
    "color": "#fbf1c7",
    "bold": false,
    "italic": true
  },
  "h5": {
    "prefix": "##### ",
    "suffix": " #####",
    "color": "#fbf1c7",
    "bold": false,
    "italic": false
  },
  "h6": {
    "prefix": "###### ",
    "suffix": " ######",
    "color": "#ebdbb2",
    "bold": false,
    "italic": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#928374",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#458588",
    "underline": true
  },
  "link_text": {
    "color": "#83a598",
    "bold": true
  },
  "image": {
    "color": "#d65d0e",
    "underline": true
  },
  "image_text": {
    "color": "#fe8019",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "background_color": "#504945"
  },
  "code_block": {
    "background_color": "#504945",
    "margin": 2,
    "theme": "gruvbox"
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}